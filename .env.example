# LinkRSP — 环境变量模板
# 复制为 .env，填写真实值（.env 已在 .gitignore 中排除）

# ── 数据库（Supabase PostgreSQL 直连）──────────────────────────────────────────
# 获取路径：Supabase 项目 > Project Settings > Database > Connection string
# 使用 Transaction mode (port 6543) 连接池 URL，结尾加 ?sslmode=require
DATABASE_URL=postgresql://postgres.yxthiltengrbmpsweool:[YOUR-DB-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── 服务配置 ───────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info                 # debug | info | warn | error
ENV=development                # development | production

# ── Supabase（预留，Phase E LLM 集成或 Auth 时使用）───────────────────────────
SUPABASE_URL=https://yxthiltengrbmpsweool.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # 仅后端使用，绝不提交到代码库
